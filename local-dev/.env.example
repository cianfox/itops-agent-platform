# ============================================================
# ITOps Agent Platform - 本地开发环境配置
# ============================================================
# 使用说明：
#   1. 复制此文件为 .env：copy .env.example .env
#   2. 根据需要修改下面的配置
#   3. 运行: docker-compose up --build
# ============================================================

# 后端配置
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_PATH=/app/data/app.db

# JWT密钥 - 仅用于开发环境
JWT_SECRET=dev-jwt-secret-not-for-production-use

# AI模型配置（按需配置）
DOUBAO_API_KEY=
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-4o

OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 日志级别
LOG_LEVEL=debug